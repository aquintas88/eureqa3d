# ── Eureqa3D — Variables de entorno ────────────────────────────

# PostgreSQL (Railway)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Sesión Express
SESSION_SECRET=cambia-esto-en-produccion

# Usuario admin inicial (solo se crea si la tabla users está vacía)
ADMIN_EMAIL=admin@eureqa3d.com
ADMIN_PASSWORD=changeme

# Correo de leads (opcional). Si se definen, el formulario de contacto y
# el chat enviarán un correo además de guardar el lead en la base de datos.
# SMTP_HOST=smtp.tu-proveedor.com
# SMTP_PORT=587
# SMTP_USER=info@eureqa3d.com
# SMTP_PASS=tu-contraseña-o-app-password
# LEAD_TO=info@eureqa3d.com   # destino (por defecto, SMTP_USER)
